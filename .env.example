# ==========================================
# Shopify Storefront API
# ==========================================
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=your_storefront_api_token

# Customer Account API
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your_customer_account_client_id
SHOPIFY_CUSTOMER_ACCOUNT_API_URL= url/account/customer/api/2026-04/graphql
SHOPIFY_CUSTOMER_AUTH_URL=url/authentication/oauth/authorize
SHOPIFY_CUSTOMER_TOKEN_URL=url/authentication/oauth/token
SHOPIFY_CUSTOMER_LOGOUT_URL=url/authentication/logout

# Genera con: openssl rand -base64 32
CUSTOMER_SESSION_SECRET=

# Shared secret for the orders/create webhook (Shopify admin →
# Settings → Notifications → Webhooks). Used to verify HMAC.
SHOPIFY_WEBHOOK_SECRET=

# ==========================================
# Site configuration (client-accessible)
# ==========================================
NEXT_PUBLIC_SITE_URL=https://folkasolutions.com

# ==========================================
# Contact channels
# ==========================================
NEXT_PUBLIC_WHATSAPP_NUMBER=528112345678
NEXT_PUBLIC_WHATSAPP_SERVICE_NUMBER=528112345678
NEXT_PUBLIC_CONTACT_EMAIL=hola@folkasolutions.com
NEXT_PUBLIC_COMMERCIAL_EMAIL=comercial@folkasolutions.com

# ==========================================
# Social profiles
# ==========================================
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/folkasolutions/
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/folkaforeveryone/

# ==========================================
# Cloudinary (image CDN)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME is used by the image loader (client-side)
# CLOUDINARY_API_KEY / CLOUDINARY_API_SECRET are server-only (upload script)
# ==========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=insightcollective
CLOUDINARY_CLOUD_NAME=insightcollective
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# Translation pipeline (optional, dev-only)
# Only required if running `npm run translate`
# ==========================================
ANTHROPIC_API_KEY=
